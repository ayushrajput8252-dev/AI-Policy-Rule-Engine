# Backend Settings
# Python/FastAPI environment variables
ENVIRONMENT=development
PORT=8000

# Gemini API Configuration
# Get this from Google AI Studio
GEMINI_API_KEY=your_gemini_api_key_here

# Pinecone Vector DB
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=your_pinecone_environment_here
PINECONE_INDEX_NAME=policy-rules

# Relational Database
# SQLite (POC)
DATABASE_URL=sqlite:///./policy_engine.db
# PostgreSQL (Production example)
# DATABASE_URL=postgresql://user:password@localhost:5432/policy_engine

# Redis / Celery settings for asynchronous background processing
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# HuggingFace (Optional: For caching models like facebook/bart-large-mnli)
HF_HOME=./.cache/huggingface

# Frontend Settings (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
